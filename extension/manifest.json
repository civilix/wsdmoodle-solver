{
  "manifest_version": 3,
  "name": "Moodle Quiz Extractor (LaTeX / PDF)",
  "version": "1.0.1",
  "description": "Extract Moodle quiz questions (with math formulas) as plain-text LaTeX or printable PDF for feeding into LLMs.",
  "content_scripts": [
    {
      "matches": [
        "*://*/mod/quiz/attempt.php*",
        "*://*/mod/quiz/review.php*",
        "*://*/mod/quiz/processattempt.php*"
      ],
      "js": ["lib/mathml-to-latex.min.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["clipboardWrite"]
}
